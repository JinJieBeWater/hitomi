{
  "name": "hitomi",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/node": "^22.13.14",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "@orpc/server": "^1.12.2",
      "@orpc/client": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "1.5.5"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types --filter=@hitomi/api --filter=@hitomi/auth --filter=@hitomi/db --filter=@hitomi/env && sh ./scripts/check-types-web.sh",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @hitomi/db db:push",
    "db:studio": "turbo -F @hitomi/db db:studio",
    "db:generate": "turbo -F @hitomi/db db:generate",
    "db:migrate": "turbo -F @hitomi/db db:migrate",
    "db:local": "turbo -F @hitomi/db db:local",
    "smoke:admin": "bun run packages/api/scripts/smoke-admin.ts",
    "smoke:admin-ui": "bun run packages/api/scripts/smoke-admin-ui.ts",
    "smoke:device": "bun run packages/api/scripts/smoke-device.ts",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@hitomi/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@hitomi/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "playwright-core": "^1.58.2",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "overrides": {
    "@vue/devtools-api": "^8.0.7"
  },
  "packageManager": "bun@1.3.11"
}
