{
  "name": "web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "zsh -lc 'node ./node_modules/nuxt/bin/nuxt.mjs build'",
    "check-types": "zsh -lc 'node ./node_modules/nuxt/bin/nuxt.mjs prepare && tsc --noEmit -p .nuxt/tsconfig.server.json && npm exec --yes --cache ../../output/tmp/npm-cache --package vue-tsc -- vue-tsc --noEmit -p tsconfig.typecheck.json'",
    "dev": "zsh -lc 'node ./node_modules/nuxt/bin/nuxt.mjs dev'",
    "generate": "zsh -lc 'node ./node_modules/nuxt/bin/nuxt.mjs generate'",
    "preview": "zsh -lc 'node ./node_modules/nuxt/bin/nuxt.mjs preview'",
    "postinstall": "zsh -lc 'node ./node_modules/nuxt/bin/nuxt.mjs prepare'"
  },
  "dependencies": {
    "@hitomi/api": "workspace:*",
    "@hitomi/auth": "workspace:*",
    "@hitomi/db": "workspace:*",
    "@hitomi/env": "workspace:*",
    "@libsql/client": "catalog:",
    "@nuxt/ui": "^4.5.1",
    "@orpc/client": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/tanstack-query": "^1.13.6",
    "@orpc/zod": "catalog:",
    "@tanstack/vue-query": "^5.92.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "libsql": "catalog:",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@hitomi/config": "workspace:*",
    "@iconify-json/lucide": "^1.2.96",
    "@tanstack/vue-query-devtools": "^6.1.5",
    "typescript": "catalog:"
  }
}
